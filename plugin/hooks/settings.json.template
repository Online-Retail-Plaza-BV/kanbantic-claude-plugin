{
  "_comment": "Kanbantic Agent Communication Hub — transcript-mirror hooks. Copy these entries into your ~/.claude/settings.json (or project-level .claude/settings.json) to enable live transcript-streaming from your Claude Code sessions to the Kanbantic UI. Requires KANBANTIC_API_KEY env var + a registered AgentSession (call register_agent_session at session-start). Hook scripts read the Kanbantic session-file written by the stdio proxy at ~/.claude-kanbantic-session.json — when no active session exists, hooks silently no-op so they don't block your prompt.",

  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"%USERPROFILE%/.claude/plugins/cache/kanbantic/kanbantic-claude-plugin/2.2.0/hooks/UserPromptSubmit.ps1\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"%USERPROFILE%/.claude/plugins/cache/kanbantic/kanbantic-claude-plugin/2.2.0/hooks/PreToolUse.ps1\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"%USERPROFILE%/.claude/plugins/cache/kanbantic/kanbantic-claude-plugin/2.2.0/hooks/PostToolUse.ps1\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File \"%USERPROFILE%/.claude/plugins/cache/kanbantic/kanbantic-claude-plugin/2.2.0/hooks/Stop.ps1\""
          }
        ]
      }
    ]
  }
}
